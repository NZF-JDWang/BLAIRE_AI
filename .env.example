# Environment
APP_ENV=production
LOG_LEVEL=info
NODE_ENV=production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DOCS_ENABLED=false
API_ALLOWED_HOSTS=localhost,127.0.0.1,backend
NEXT_PUBLIC_API_BASE_URL=/api
INTERNAL_API_BASE_URL=http://backend:8000
FRONTEND_PROXY_API_KEY=change_me_admin_key

# Database
POSTGRES_DB=blaire
POSTGRES_USER=blaire
POSTGRES_PASSWORD=change_me
POSTGRES_DATA_PATH=./data/postgres
DATABASE_URL=postgresql+psycopg://blaire:change_me@postgres:5432/blaire

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_LOG_LEVEL=INFO
QDRANT_STORAGE_PATH=/srv/blacksitelab/blaire/qdrant
QDRANT_COLLECTION_NAME=knowledge_multimodal
QDRANT_EMBEDDING_DIM=768

# Inference
INFERENCE_BASE_URL=http://localai:8080
VLLM_BASE_URL=http://vllm:8000
LOCALAI_MODELS_PATH=./data/localai/models
LOCALAI_DEBUG=false
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Search
SEARCH_MODE_DEFAULT=searxng_only
BRAVE_API_KEY=
SEARXNG_URL=http://searxng:8080
SEARXNG_BASE_URL=http://searxng:8080/
SEARXNG_INSTANCE_NAME=blaire-searxng
SEARXNG_CONFIG_PATH=./data/searxng
SEARXNG_REDIS_URL=

# Knowledge + Storage
DROP_FOLDER=/srv/ai-knowledge/drop
OBSIDIAN_VAULT_PATH=/srv/obsidian/BlacksiteLabVault
BACKUP_PATH=/mnt/backups/blaire
LOG_PATH=./data/logs
MAX_UPLOAD_MB=25
AGENT_MAX_TOOL_CALLS=4
AGENT_MAX_RECURSION_DEPTH=2
AGENT_WORKER_TIMEOUT_SECONDS=12
AGENT_OVERALL_TIMEOUT_SECONDS=20
SANDBOX_ALLOWED_COMMANDS=echo
CLI_SANDBOX_BACKEND=firejail
CLI_SANDBOX_ENABLED=false
PIPER_BIN=piper
PIPER_VOICE_MODEL=
FASTER_WHISPER_BIN=faster-whisper
FASTER_WHISPER_MODEL=small
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
GOOGLE_API_BASE=https://www.googleapis.com
GOOGLE_OAUTH_TOKEN=
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# MCP endpoints
MCP_OBSIDIAN_URL=http://obsidian-mcp-server:3000
MCP_HA_URL=http://ha-mcp-server:3000
MCP_HOMELAB_URL=http://homelab-mcp:3000

# Sensitive action controls
SENSITIVE_ACTIONS_ENABLED=true
APPROVAL_TOKEN_TTL_MINUTES=10

# Models (class defaults; runtime-selectable in app policy)
MODEL_GENERAL_DEFAULT=qwen2.5:7b-instruct
MODEL_VISION_DEFAULT=qwen2.5vl:7b
MODEL_EMBEDDING_DEFAULT=nomic-embed-text:v1.5
MODEL_CODE_DEFAULT=
MODEL_ALLOW_ANY_INFERENCE=false
ALLOW_ANY_VISION_MODELS=false

ALLOWED_NETWORK_HOSTS=
ALLOWED_NETWORK_TOOLS=network_probe
ALLOWED_WRITE_PATHS=/app/knowledge/drop
ALLOWED_OBSIDIAN_PATHS=
ALLOWED_HA_OPERATIONS=
ALLOWED_HOMELAB_OPERATIONS=
REQUIRE_AUTH=true
ADMIN_API_KEYS=change_me_admin_key
USER_API_KEYS=change_me_user_key

