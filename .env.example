# Environment
APP_ENV=production
LOG_LEVEL=info
NODE_ENV=production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DOCS_ENABLED=false
API_ALLOWED_HOSTS=localhost,127.0.0.1,backend
NEXT_PUBLIC_API_BASE_URL=http://backend:8000

# Database
POSTGRES_DB=blaire
POSTGRES_USER=blaire
POSTGRES_PASSWORD=change_me
POSTGRES_DATA_PATH=./data/postgres
DATABASE_URL=postgresql+psycopg://blaire:change_me@postgres:5432/blaire

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_LOG_LEVEL=INFO
QDRANT_STORAGE_PATH=/srv/blacksitelab/blaire/qdrant

# Inference
OLLAMA_BASE_URL=http://ollama:11434

# Search
SEARCH_MODE_DEFAULT=searxng_only
BRAVE_API_KEY=
SEARXNG_URL=http://searxng:8080
SEARXNG_BASE_URL=http://searxng:8080/
SEARXNG_INSTANCE_NAME=blaire-searxng
SEARXNG_CONFIG_PATH=./data/searxng
SEARXNG_REDIS_URL=

# Knowledge + Storage
DROP_FOLDER=/srv/ai-knowledge/drop
OBSIDIAN_VAULT_PATH=/srv/obsidian/BlacksiteLabVault
BACKUP_PATH=/mnt/backups/blaire
LOG_PATH=./data/logs

# MCP endpoints
MCP_OBSIDIAN_URL=http://obsidian-mcp-server:3000
MCP_HA_URL=http://ha-mcp-server:3000

# Sensitive action controls
SENSITIVE_ACTIONS_ENABLED=true
APPROVAL_TOKEN_TTL_MINUTES=10

# Models (class defaults; runtime-selectable in app policy)
MODEL_GENERAL_DEFAULT=qwen2.5:7b-instruct
MODEL_VISION_DEFAULT=qwen2.5vl:7b
MODEL_EMBEDDING_DEFAULT=nomic-embed-text:v1.5
MODEL_CODE_DEFAULT=

ALLOWED_NETWORK_HOSTS=
ALLOWED_NETWORK_TOOLS=network_probe
ALLOWED_WRITE_PATHS=/app/knowledge/drop

